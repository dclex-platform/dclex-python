# Local stack environment for SDK integration tests.
#
# Copy this file to .env.local and fill in PRIMEDELTA_TEST_PRIVATE_KEY.
# When .env.local exists, conftest.py loads it instead of .env.

# Private key of a verified + DID-minted account on the local anvil
# (must hold gas + USDC, and a stock balance for the chosen symbol).
PRIMEDELTA_TEST_PRIVATE_KEY=0x...

# Optional second key — a fresh account with NO DID minted, used to verify
# DID-required actions raise AccountNotVerified. Skip those tests if unset.
PRIMEDELTA_UNVERIFIED_PRIVATE_KEY=

# Local stack URLs.
PRIMEDELTA_PROVIDER_URL=http://localhost:8545
PRIMEDELTA_BASE_URL=http://localhost:8000
PRIMEDELTA_APP_URL=http://localhost:5173

# Symbol used by the dex tests. Pool must be registered on the backend.
PRIMEDELTA_TEST_SYMBOL=AAPL
