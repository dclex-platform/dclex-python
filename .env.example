# PrimeDelta SDK - Environment Variables for Integration Tests
#
# Copy this file to .env and fill in your values
# These are required for running integration tests (tests/integration/)

# Private key of a verified test account (with 0x prefix).
# Account must be VERIFIED and DID_MINTED in the target backend, and hold
# enough native gas + USDC to cover the test transactions.
PRIMEDELTA_TEST_PRIVATE_KEY=0x...

# Optional: a second key for a fresh account (NOT verified) used to test
# that DID-required actions raise AccountNotVerified. If unset, those
# tests are skipped.
PRIMEDELTA_UNVERIFIED_PRIVATE_KEY=

# Web3 RPC provider URL
PRIMEDELTA_PROVIDER_URL=https://besu-dev.primedelta.io

# Backend API base URL. Override for local stack (e.g. http://localhost:8000).
PRIMEDELTA_BASE_URL=https://api-dev.primedelta.io

# Frontend app base URL used for SIWE + verification redirect.
PRIMEDELTA_APP_URL=https://app-dev.primedelta.io

# Symbol used in the dex integration tests; must have a registered DCLEX
# pool (and ideally an AMM pool) on the target backend.
PRIMEDELTA_TEST_SYMBOL=AAPL
